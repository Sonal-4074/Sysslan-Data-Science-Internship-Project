   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"Dataset1.csv\")\n",
    "\n",
    "\n",
    "model_data = df.groupby(\"Train_No\").agg(\n",
    "    Total_Distance=(\"Distance\", \"max\"),\n",
    "    Number_of_Stops=(\"Station_Name\", \"count\")\n",
    ").reset_index()\n",
    "\n",
    "\n",
    "model_data.head(10)"
   ]
